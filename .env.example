# -------------------------------------------------------
# TurboCharity -- Environment Variables
# Copy this file to .env.local and fill in the values.
# -------------------------------------------------------

# Public site URL used for canonical links, OG images, and sitemap generation.
# Include the protocol (https://) and omit the trailing slash.
NEXT_PUBLIC_SITE_URL=https://turbocharity.com

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# Leave blank or remove to disable analytics in development.
NEXT_PUBLIC_GA_ID=

# PostHog project API key (e.g. phc_XXXXXXXXXX).
# Leave blank or remove to disable PostHog tracking.
NEXT_PUBLIC_POSTHOG_KEY=

# Supabase connection details
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
