# -------------------------------------------------------
# TurboCharity -- Environment Variables
# Copy this file to .env.local and fill in the values.
# -------------------------------------------------------

# Public site URL used for canonical links, OG images, and sitemap generation.
# Include the protocol (https://) and omit the trailing slash.
NEXT_PUBLIC_SITE_URL=https://turbocharity.com

# Public site name
NEXT_PUBLIC_SITE_NAME=TurboCharity

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# Leave blank or remove to disable analytics in development.
NEXT_PUBLIC_GA_ID=

# Supabase connection details
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend API key for transactional emails
RESEND_API_KEY=
